/*
Problem: Missing Number in Array
Platform: GeeksforGeeks

Description:
You are given an array arr of size n-1 containing distinct numbers from 1 to n.
One number is missing. Find the missing number.

Example:
Input: arr = [1,2,3,5]
Output: 4
*/

class Solution {
    int missingNum(int arr[]) {
        int n=arr.length+1;
        long total_sum=(long)n*(n+1)/2;
        long sum=0;
        for (int i=0;i<arr.length;i++)
        {
            sum+=arr[i];
        }
        return (int)(total_sum-sum);
     }
}
